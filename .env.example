# === WYMAGANE ===
MCP_USER=admin
MCP_PASS=ZMIEN_NA_DLUGIE_HASLO_MIN_20_ZNAKOW
MCP_BASE_URL=https://your-domain.com

# === OPCJONALNE - GitHub integration ===
# Token z https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
GITHUB_OWNER=

# === OPCJONALNE - server tuning ===
# Port na którym słucha node (default 4500)
PORT=4500
# Czas życia access tokena w sekundach (default 30 dni = 2592000)
TOKEN_TTL_SECONDS=2592000
# Czas życia authorization code w sekundach (default 600 = 10 min)
AUTH_CODE_TTL_SECONDS=600
# Max output buffer w MB dla shell commands (default 10)
EXEC_BUFFER_MB=10

# === OPCJONALNE - pliki konfiguracyjne ===
# Domyślnie ./hosts.json
HOSTS_CONFIG=./hosts.json
# Server name w MCP protokole (widoczne w Claude.ai)
MCP_SERVER_NAME=my-mcp-server