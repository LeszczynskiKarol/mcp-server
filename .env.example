# === REQUIRED ===
MCP_USER=admin
# Use a long random password (20+ chars). Generate with: openssl rand -base64 32
MCP_PASS=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD_MIN_20_CHARS
# Your public HTTPS URL (no trailing slash). Required by Claude.ai OAuth.
MCP_BASE_URL=https://your-domain.com

# === OPTIONAL - GitHub integration ===
# Personal Access Token from https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
GITHUB_OWNER=

# === OPTIONAL - server tuning ===
# Port the node server listens on (default 4500)
PORT=4500
# Access token lifetime in seconds (default 30 days = 2592000)
TOKEN_TTL_SECONDS=2592000
# Authorization code lifetime in seconds (default 600 = 10 min)
AUTH_CODE_TTL_SECONDS=600
# Max output buffer in MB for shell commands (default 10)
EXEC_BUFFER_MB=10
# Timeout in seconds for shell commands (default 120)
EXEC_TIMEOUT_SECONDS=120

# === OPTIONAL - config files ===
# Path to hosts.json (default ./hosts.json)
HOSTS_CONFIG=./hosts.json
# Server name in the MCP protocol (visible in Claude.ai connector UI)
MCP_SERVER_NAME=my-mcp-server

# Client registration TTL in seconds (default 90 days = 7776000)
CLIENT_TTL_SECONDS=7776000
# Path to OAuth state file (default ./oauth-state.json)
OAUTH_STATE_FILE=./oauth-state.json

# === OPTIONAL - IP allowlist ===
# Comma-separated static IPs/CIDRs that are always allowed.
# Leave empty if you only want auto-enroll via OAuth login.
# Examples: MCP_ALLOWED_IPS=83.21.45.67  or  MCP_ALLOWED_IPS=83.21.0.0/16
MCP_ALLOWED_IPS=
# Trust X-Forwarded-For header (set true if behind FRP/Cloudflare/nginx)
MCP_TRUST_PROXY=loopback
# Auto-enroll IPs to allowlist after successful OAuth login (default true)
MCP_AUTO_ENROLL=true
# How long an auto-enrolled IP stays on the allowlist (default 30 days)
MCP_ENROLL_TTL_SECONDS=2592000

# === OPTIONAL - AWS Security Group auto-sync for SSH ===
# When a host in hosts.json has 'security_group_id' set, ssh_exec/pm2_status/
# postgres_query auto-add the local public IP to that SG on port 22 (and
# revoke stale 'mcp-auto-ssh' tagged rules). This env controls how long
# the success result is cached before the next AWS API check.
# Default 60000 ms = 60s.
SG_CHECK_TTL_MS=60000
