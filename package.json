    "mcp",
    "mcp-server",
    "claude",
    "claude-ai",
    "anthropic",
    "model-context-protocol",
    "oauth",
    "oauth2",
    "self-hosted",
    "aws",
    "ssh",
    "github-api",
    "postgresql",
    "pm2",
    "nodejs",
    "express",
    "developer-tools"
  ],
  "author": "Karol Leszczynski <kontakt@karol-leszczynski.pl>",
