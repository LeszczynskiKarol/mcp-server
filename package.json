  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeszczynskiKarol/mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/LeszczynskiKarol/mcp-server/issues"
  },
  "homepage": "https://github.com/LeszczynskiKarol/mcp-server#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
